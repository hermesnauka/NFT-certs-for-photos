# Backend base URL used by:
#  - server components (fetch directly, no browser CORS involved)
#  - the /api/* rewrite proxy in next.config.js (used by client-side fetches)
BACKEND_URL=http://localhost:8080

# Optional: enables the WalletConnect connector in addition to injected/MetaMask.
# Get a project ID at https://cloud.walletconnect.com. Leave unset to skip WalletConnect.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
